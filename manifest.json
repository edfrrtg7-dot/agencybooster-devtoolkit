{
  "manifest_version": 3,
  "name": "AgencyBooster Developer Toolkit",
  "description": "Developer toolkit for GoldenBride investigation.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AgencyBooster Developer Toolkit"
  }
}
